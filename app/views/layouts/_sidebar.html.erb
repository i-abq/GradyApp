<aside class="sidebar" id="sidebar" data-sidebar-target="sidebar">
  <div class="sidebar-header">
    <a href="/" class="logo">
      <%= image_tag "logos/logo-topbar.svg", alt: "GradyApp Logo" %>
    </a>
    <button class="btn-icon" id="sidebar-close-btn" data-action="click->sidebar#close">
      <%= image_tag 'icons/circle-x-icon.svg', alt: 'Fechar' %>
    </button>
  </div>
  <ul class="sidebar-menu">
    <li>
      <a href="<%= app_root_path %>" class="active">
        <%= image_tag 'icons/home-icon.svg', alt: 'Início' %>
        <span>Início</span>
      </a>
    </li>
    <li>
      <a href="https://app.grady.com.br/questions">
        <%= image_tag 'icons/layout-list-icon.svg', alt: 'Questões' %>
        <span>Questões</span>
      </a>
    </li>
    <li>
      <a href="https://app.grady.com.br/booklets">
        <%= image_tag 'icons/book-open-check-icon.svg', alt: 'Cadernos de Prova' %>
        <span>Cadernos de Prova</span>
      </a>
    </li>
    <li>
      <a href="https://app.grady.com.br/layouts">
        <%= image_tag 'icons/sliders-horizontal-icon.svg', alt: 'Layouts' %>
        <span>Layouts</span>
      </a>
    </li>
    <li>
      <a href="https://app.grady.com.br/results">
        <%= image_tag 'icons/file-check-icon.svg', alt: 'Resultados' %>
        <span>Resultados</span>
      </a>
    </li>
  </ul>
</aside> 